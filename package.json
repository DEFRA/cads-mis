{
  "name": "cads-mis",
  "version": "0.0.0",
  "description": "CDP Frontend Template",
  "license": "OGL-UK-3.0",
  "author": "Defra DDTS",
  "sideEffects": false,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "build:frontend": "webpack --mode production",
    "dev": "concurrently \"npm:frontend:watch\" \"npm:server:watch\"",
    "dev:debug": "concurrently \"npm:frontend:watch\" \"npm:server:debug\"",
    "docker:debug": "docker compose -f compose.yaml -f compose.debug.yaml -p \"cads-mis\" build --no-cache && docker compose -f compose.yaml -f compose.debug.yaml -p \"cads-mis\" up",
    "docker:dev": "npm run dev",
    "docker:up": "docker compose up",
    "format": "prettier --write \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js}\"",
    "frontend:watch": "webpack --watch --mode development",
    "git:pre-commit-hook": "npm run format:check && npm run lint && npm test",
    "postinstall": "npm run setup:husky",
    "lint": "concurrently \"npm:lint:js\" \"npm:lint:scss\"",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:scss": "stylelint \"src/**/*.scss\" --cache --cache-location .cache/stylelint --cache-strategy content --color --ignore-path .gitignore",
    "security-audit": "npm audit --omit=dev --audit-level=high",
    "server:debug": "nodemon --inspect-brk=0.0.0.0 --ext js,json --legacy-watch ./src",
    "server:watch": "nodemon --inspect=0.0.0.0 --ext js,json --legacy-watch ./src",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "prestart": "npm run build:frontend",
    "start": "node --use-strict .",
    "start:debug": "nodemon --watch src --exec \"node --experimental-vm-modules --inspect=0.0.0.0 src/index.js\"",
    "pretest": "npm run build:frontend",
    "test": "vitest run --coverage",
    "test:lint": "standard",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@defra/cdp-auditing": "0.1.0",
    "@defra/hapi-secure-context": "0.1.3",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/catbox-memory": "6.0.2",
    "@hapi/catbox-redis": "7.0.2",
    "@hapi/hapi": "21.4.0",
    "@hapi/inert": "7.1.0",
    "@hapi/scooter": "7.0.0",
    "@hapi/vision": "7.0.3",
    "@hapi/yar": "11.0.3",
    "aws-embedded-metrics": "4.2.0",
    "blankie": "5.0.0",
    "convict": "6.2.4",
    "convict-format-with-validator": "6.2.0",
    "cssnano": "7.0.7",
    "cssnano-preset-default": "7.0.7",
    "date-fns": "4.1.0",
    "global-agent": "3.0.0",
    "govuk-frontend": "5.11.0",
    "hapi-pino": "12.1.0",
    "hapi-pulse": "3.0.1",
    "ioredis": "5.6.1",
    "lodash": "4.17.23",
    "node-fetch": "3.3.2",
    "nunjucks": "3.2.4",
    "pino": "9.7.0",
    "pino-pretty": "13.0.0",
    "semver": "7.7.2",
    "undici": "7.22.0"
  },
  "devDependencies": {
    "@babel/preset-env": "7.27.2",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/eslint-plugin": "1.1.31",
    "autoprefixer": "10.4.21",
    "babel-loader": "10.0.0",
    "cheerio": "1.1.0",
    "concurrently": "9.2.1",
    "copy-webpack-plugin": "13.0.0",
    "eslint": "10.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-package-json": "0.89.0",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "neostandard": "0.12.2",
    "nodemon": "3.1.14",
    "postcss-load-config": "6.0.1",
    "postcss-loader": "8.2.1",
    "prettier": "3.5.3",
    "sass-embedded": "1.97.3",
    "sass-loader": "16.0.7",
    "source-map-loader": "5.0.0",
    "stylelint": "16.21.0",
    "stylelint-config-gds": "2.0.0",
    "terser-webpack-plugin": "5.3.14",
    "vitest": "4.0.18",
    "vitest-fetch-mock": "0.4.5",
    "webpack": "5.105.2",
    "webpack-assets-manifest": "6.2.1",
    "webpack-cli": "6.0.1"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
