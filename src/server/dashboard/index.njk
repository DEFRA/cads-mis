{% extends 'layouts/page.njk' %}
{% from "report-item/macro.njk" import appReportItem %}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: "Select a report to open the corresponding CADS management information dashboard."
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column">
      <div class="govuk-body" data-testid="app-page-body">
        <main class="govuk-main-wrapper ">
            <div class="govuk-grid-row">
              {% for item in viewModel.reports %}
                {{ appReportItem(item) }}
              {% else %}
                <div class="govuk-summary-card__content">
                  <p class="govuk-body-s">No reports found.</p>
                </div>
              {% endfor %}
            </div>
        </main>
      </div>
    </div>
  </div>

{% endblock %}
