# Environment configuration
NODE_ENV=test
APP_BASE_URL=http://localhost:3000

# OIDC authentication
OIDC_WELL_KNOWN_URL=http://localhost:5557/.well-known/openid-configuration
OIDC_CLIENT_ID=test-client
OIDC_CLIENT_SECRET=test-secret
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/auth/signed-out
OIDC_POST_LOGIN_REDIRECT_URI=/dashboard

## Resource: CADS CDS
AZURE_CLIENT_CADS_CDS_ID=test-cads-cds
USE_SIMPLE_SCOPES=true

# Session configuration
SESSION_CACHE_ENGINE=memory
SESSION_COOKIE_PASSWORD=test-password

# Redis configuration (not used in tests, but required by config schema)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=test
REDIS_KEY_PREFIX=test
USE_SINGLE_INSTANCE_CACHE=true